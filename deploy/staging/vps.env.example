COMPOSE_PROJECT_NAME=instruments-platform-staging
POSTGRES_DB=instruments_platform_staging
POSTGRES_USER=platform_app
POSTGRES_PASSWORD=replace-with-staging-password
POSTGRES_RUNTIME_USER=platform_app_runtime
POSTGRES_RUNTIME_PASSWORD=replace-with-runtime-password
POSTGRES_WORKER_USER=platform_worker
POSTGRES_WORKER_PASSWORD=replace-with-worker-password
API_HTTP_PORT=5055
WEB_HTTP_PORT=5174
STAGING_WEB_ORIGIN=https://staging.example.com
STAGING_API_ORIGIN=https://staging-api.example.com
Cors__AllowedOrigins__0=https://staging.example.com
PUBLIC_API_BASE_URL=https://staging-api.example.com
PUBLIC_DEV_AUTH_ENABLED=false
PUBLIC_DEV_TENANT_ID=11111111-1111-4111-8111-111111111111
PUBLIC_DEV_USER_ID=22222222-2222-4222-8222-222222222222
PUBLIC_TENANT_ID=11111111-1111-4111-8111-111111111111
PUBLIC_AUTH_LOGIN_URL=https://staging-api.example.com/auth/login?returnUrl=https%3A%2F%2Fstaging.example.com%2Fapp
PUBLIC_AUTH_LOGOUT_URL=https://staging-api.example.com/auth/logout?returnUrl=https%3A%2F%2Fstaging.example.com%2F
Authentication__Oidc__InteractiveEnabled=true
Authentication__Oidc__Authority=https://replace-with-auth0-domain/
Authentication__Oidc__ClientId=replace-with-auth0-client-id
Authentication__Oidc__ClientSecret=replace-with-auth0-client-secret
Authentication__Oidc__CallbackPath=/auth/callback
Authentication__Oidc__SignedOutCallbackPath=/auth/signout-callback
Authentication__Oidc__RequireHttpsMetadata=true
Authentication__Oidc__RequireVerifiedEmail=true
Authentication__Oidc__ProviderKey=auth0
Authentication__Oidc__EmailClaim=email
Authentication__Oidc__SubjectClaim=sub
Authentication__Oidc__SubjectTenantClaim=
Authentication__Oidc__AssumeEmailVerifiedWhenClaimMissing=false
Authentication__Oidc__ProviderLogoutMode=auth0
DirectoryImports__MicrosoftGraph__ClientId=replace-with-graph-import-client-id
DirectoryImports__MicrosoftGraph__ClientSecret=replace-with-graph-import-client-secret
DirectoryImports__MicrosoftGraph__AdminConsentRedirectUri=https://api-staging.validatedscale.com/directory-connections/microsoft-graph/admin-consent/callback
DirectoryImports__MicrosoftGraph__PostConsentRedirectUrl=https://staging.validatedscale.com/app/directory
DirectoryImports__MicrosoftGraph__AdminConsentTenant=organizations
ReverseProxy__ForwardedHeaders__Enabled=true
EmailDelivery__Provider=local-dev
EmailDelivery__SenderDomainVerified=false
EmailDelivery__VerifiedSenderDomain=
EmailDelivery__FromAddress=
EmailDelivery__PublicAppBaseUrl=https://staging.validatedscale.com
EmailDelivery__InvitationFooterText=
EmailDelivery__AzureCommunicationServices__ConnectionString=
EmailDelivery__AzureCommunicationServices__Endpoint=
EmailDelivery__AzureCommunicationServices__AccessKey=
EmailDelivery__AzureCommunicationServices__EventGridWebhookSecret=
EmailDelivery__AzureCommunicationServices__DisableUserEngagementTracking=true
OutboxRelay__Enabled=true
OutboxRelay__BatchSize=100
OutboxRelay__PollIntervalSeconds=1
OutboxRelay__ProcessOnStartup=true
WorkerHeartbeat__Enabled=true
WorkerHeartbeat__WorkerName=platform-workers
WorkerHeartbeat__InitialDelaySeconds=5
WorkerHeartbeat__IntervalSeconds=30
RetentionAutomation__Enabled=false
ReportPdfArtifacts__Enabled=false
ExportArtifacts__ObjectStore__Provider=local
ExportArtifacts__ObjectStore__RootPath=/var/lib/instruments-platform/export-artifacts
ExportArtifacts__ObjectStore__S3__Endpoint=
ExportArtifacts__ObjectStore__S3__BucketName=
ExportArtifacts__ObjectStore__S3__Region=us-east-1
ExportArtifacts__ObjectStore__S3__AccessKeyId=
ExportArtifacts__ObjectStore__S3__SecretAccessKey=
Reports__PdfRenderer__BrowserExecutablePath=/usr/bin/chromium
Reports__PdfRenderer__TimeoutMilliseconds=30000
Reports__PdfRenderer__DisableSandbox=true
