{
  "ConnectionStrings": {
    "PlatformDb": "Host=localhost;Port=5432;Database=instruments_platform_dev;Username=platform_app;Password=platform_app_dev"
  },
  "OutboxRelay": {
    "Enabled": true,
    "BatchSize": 100,
    "PollIntervalSeconds": 1,
    "ProcessOnStartup": true
  },
  "RetentionAutomation": {
    "Enabled": false,
    "InitialDelaySeconds": 30,
    "IntervalSeconds": 3600,
    "MaxBatchesPerTenant": 10,
    "MaxTenantsPerTick": 50
  },
  "ReportPdfArtifacts": {
    "Enabled": false,
    "InitialDelaySeconds": 30,
    "IntervalSeconds": 60,
    "RenderingTimeoutMinutes": 30,
    "MaxArtifactsPerTenant": 10,
    "MaxTenantsPerTick": 50
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
